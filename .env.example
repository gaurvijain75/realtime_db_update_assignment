# copy this file to .env and fill in your values

# for local postgres:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ordersdb

# for neon.tech (free cloud postgres) — paste the connection string from their dashboard:
# DATABASE_URL=postgresql://user:password@ep-something.neon.tech/neondb?sslmode=require

PORT=3000
NODE_ENV=development
